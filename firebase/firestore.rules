rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is accessing their own document
    function isAccessingOwnData(userId) {
      return request.auth.uid == userId;
    }

    // Check if user is an admin (via custom claims)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // =========================================================================
    // EXISTING APP COLLECTIONS
    // =========================================================================

    // Users collection - each user can read/write only their own document
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isAccessingOwnData(userId);
    }

    // Interests collection - authenticated users can read, but not modify
    match /interests/{interestId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Page submissions collection - authenticated users can create and read
    match /pageSubmissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }

    // Event likes collection - authenticated users can read/write
    match /eventLikes/{eventId} {
      allow read, write: if isAuthenticated();
    }

    // Event shares collection
    match /eventShares/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.count is number
                    && request.resource.data.count >= 0;
      allow update: if isAuthenticated()
                    && request.resource.data.count is number
                    && request.resource.data.count > resource.data.count;
    }

    // Event users responded collection
    match /eventUsersResponded/{eventId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // =========================================================================
    // NEW: VENUES COLLECTION (Phase 1 Migration)
    // Public read access for guest users (unauthenticated)
    // Write access restricted to admin users only
    // =========================================================================
    match /venues/{venueId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Events subcollection (nested under venues)
      match /events/{eventId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    // Collection group query for events (cross-venue queries)
    match /{path=**}/events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================================================================
    // NEW: PROCESSING COLLECTIONS (Admin only)
    // =========================================================================

    // Tracks processed Apify export files
    match /processed_datasets/{datasetId} {
      allow read, write: if isAdmin();
    }

    // Venues that couldn't be matched during processing
    match /unrecognized_venues/{venueId} {
      allow read, write: if isAdmin();
    }

    // State for resumable batch processing
    match /processing_state/{stateId} {
      allow read, write: if isAdmin();
    }

    // =========================================================================
    // ADMINS COLLECTION (optional - for Firestore-based admin management)
    // =========================================================================
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if isAdmin();
    }

    // =========================================================================
    // DEFAULT: Deny all other access
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
