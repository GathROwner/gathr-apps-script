# Venue Migration Configuration
# Copy this file to .env and update values as needed

# Google Sheets Configuration
SPREADSHEET_ID=1w0h7TjgP551ZJ5qkb1yU6eRQVlqc6SjTDVGHDZ1qFCQ
SHEET_NAME=Contact Info

# Firebase Configuration
# Path to service account JSON (relative to migration folder or absolute)
SERVICE_ACCOUNT_PATH=../firebase/service-account.json
FIRESTORE_COLLECTION=venues

# Migration Settings
# Firestore batch write limit is 500
BATCH_SIZE=500

# Delay between batch writes in milliseconds (for rate limiting)
RATE_LIMIT_DELAY_MS=100

# Save checkpoint every N rows processed
CHECKPOINT_INTERVAL=50

# Retry Settings
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000

# Debug mode (set to "true" for verbose logging)
DEBUG=false
